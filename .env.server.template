# ─────────────────────────────────────────────────────────────────────────────
# Server Environment — copy to .env.server and fill in values
# Usage: docker-compose -f docker-compose.server.yml up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── IBKR Credentials (for IB Gateway auto-login via IBC) ────────────────────
IBKR_USERNAME=              # your IBKR paper trading username
IBKR_PASSWORD=              # your IBKR paper trading password

# ── IBKR API (set by docker-compose, but can override here) ─────────────────
IBKR_HOST=ib-gateway        # Docker service name (not 127.0.0.1)
IBKR_PORT=4002              # 4002=paper, 4001=live
IBKR_CLIENT_ID=1

# ── Database (Supabase PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres.bhztefmozidvfqmjepwa:[SUPABASE-DB-PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# ── Redis (Docker service) ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── LLM (Claude API — Ollama not available on server) ───────────────────────
OLLAMA_HOST=                # leave blank — triggers Claude fallback
ANTHROPIC_API_KEY=          # required for sentiment scoring on server

# ── Supabase (dashboard sync) ───────────────────────────────────────────────
SUPABASE_URL=https://bhztefmozidvfqmjepwa.supabase.co
SUPABASE_KEY=               # service role key

# ── Telegram Alerts ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=         # bot token
TELEGRAM_CHAT_ID=           # your chat ID

# ── Trading Parameters ─────────────────────────────────────────────────────
SIGNAL_THRESHOLD=65.0
MAX_POSITION_PCT=0.20
STOP_LOSS_PCT=0.07
PORTFOLIO_CAPITAL=20000
TRADING_PHASE=2             # 2 = IBKR paper trading
