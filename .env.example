# ── Copy this file to .env and fill in your values ───────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asx_trading
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Redis (optional — falls back to in-memory if unavailable) ─────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Gmail Alerts ──────────────────────────────────────────────────────────────
# Use an App Password (not your main password): myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=
ALERT_EMAIL_TO=you@gmail.com

# ── IBKR Live Trading (Phase 3 only) ─────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── Trading Parameters ────────────────────────────────────────────────────────
TRADING_PHASE=1           # 1=paper only, 3=live trading enabled
SIGNAL_THRESHOLD=75.0     # Minimum composite score to generate a trade
MAX_POSITION_PCT=0.20     # Max 20% of portfolio per position
STOP_LOSS_PCT=0.07        # 7% stop-loss from entry
PORTFOLIO_CAPITAL=100000  # Simulated portfolio size (AUD)

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Australia/Sydney
